Options -Indexes
RewriteEngine On

# Block access to sensitive files
<FilesMatch "\.(env|sql|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Redirect to index.php if no file found
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]